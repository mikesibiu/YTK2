# Managed PostgreSQL connection (Neon recommended)
# Example: postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_NEON_HOST/YOUR_DB?sslmode=require

# Server configuration
PORT=8080
NODE_ENV=production

# Optional: CORS allowlist for admin UI
# Example: https://your-koyeb-service.koyeb.app
# ALLOWED_ORIGINS=https://your-domain.com,https://your-koyeb-service.koyeb.app
